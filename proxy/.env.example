# ─────────────────────────────────────────────────────────────
# Xpllc-Claw Groq Proxy — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# REQUIRED: Your Groq API key (never shared with users)
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Admin key to access /admin/stats and /admin/ban/:token
# Change this to something secret!
ADMIN_KEY=change-this-to-something-secret

# Free requests per user (default: 400)
MAX_REQUESTS_PER_USER=400

# Rate limit per user per minute (default: 20)
RATE_PER_MINUTE=20

# Server port (default: 3000)
PORT=3000

# CORS origins (default: * = allow all)
CORS_ORIGINS=*

# Path to store user data (default: ./storage/users.json)
STORAGE_FILE=./storage/users.json
